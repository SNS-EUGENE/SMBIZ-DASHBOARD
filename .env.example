# ===================================================
# SMBIZ Dashboard 환경변수
# .env 파일로 복사 후 실제 값 입력
# ===================================================

# --- Supabase (프론트엔드용, VITE_ 접두사 필수) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- data.go.kr 공휴일 API (특일정보 서비스 15012690) ---
# https://www.data.go.kr/data/15012690/openapi.do 에서 활용 신청 후 발급
VITE_DATA_GO_KR_API_KEY=your_api_key_here

# --- smbiz.sba.kr 관리자 계정 (Edge Function에서만 사용) ---
# Supabase Edge Function Secrets로도 설정 필요:
#   supabase secrets set SMBIZ_ADMIN_ID=xxx SMBIZ_ADMIN_PW=xxx
SMBIZ_ADMIN_ID=your_admin_id
SMBIZ_ADMIN_PW=your_admin_pw

# --- Vercel Cron 보호 (Vercel 환경변수에 설정) ---
# 랜덤 문자열 생성: openssl rand -hex 32
CRON_SECRET=your_random_cron_secret

# --- Vercel Serverless Function용 (VITE_ 접두사 없이) ---
# Vercel Dashboard > Settings > Environment Variables에 추가
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- 카카오워크 봇 (선택, 추후 연동 시) ---
# KAKAOWORK_BOT_KEY=your_kakaowork_bot_api_key
