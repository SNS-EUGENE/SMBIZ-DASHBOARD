{
  "manifest_version": 3,
  "name": "SMBIZ 예약 데이터 추출기",
  "version": "1.0.0",
  "description": "서울도시제조허브 예약 관리 페이지에서 데이터를 추출하여 SMBIZ Dashboard에 붙여넣기할 수 있습니다.",
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://smbiz.sba.kr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://smbiz.sba.kr/biz_manage/facilityReserve/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
